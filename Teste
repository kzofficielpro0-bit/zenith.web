<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>IceHub</title>
    <link rel="icon" href="noFilter_1.webp" type="image/webp">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css?v=6">
</head>
<body>
    <div class="ambient-glow"></div>
    <style>
        @keyframes slideDownAlert {
            0% { transform: translate(-50%, -150%); opacity: 0; }
            10% { transform: translate(-50%, 20px); opacity: 1; }
            90% { transform: translate(-50%, 20px); opacity: 1; }
            100% { transform: translate(-50%, -150%); opacity: 0; }
        }
        .admin-banner-anim {
            animation: slideDownAlert 4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>

    <div id="globalBanner" style="display: none; position: fixed; top: 0; left: 50%; transform: translate(-50%, -150%); background: rgba(15, 23, 42, 0.95); border: 1px solid rgba(56, 189, 248, 0.5); color: #fff; padding: 12px 24px; font-size: 14px; font-weight: 600; border-radius: 50px; z-index: 9999; box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 15px rgba(56,189,248,0.2); backdrop-filter: blur(10px); white-space: nowrap; max-width: 90vw; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center;">
        <span style="color: #38bdf8; margin-right: 8px; font-weight: 800;">[ADMIN]</span> <span id="bannerText"></span>
    </div>

    <style>
        @keyframes slideDownAlert {
            0% { transform: translateY(-100%); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        .admin-banner-anim {
            animation: slideDownAlert 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            box-shadow: 0 4px 20px rgba(29, 107, 252, 0.2);
        }
    </style>

    <div style="position: absolute; top: 22px; left: 50%; transform: translateX(-50%); font-size: 11px; color: var(--ok); font-weight: 700; z-index: 1000; letter-spacing: 1px; display: flex; align-items: center; gap: 6px;">
        <span style="display:inline-block; width:6px; height:6px; background:var(--ok); border-radius:50%; box-shadow: 0 0 8px var(--ok);"></span>
        ONLINE: <span id="onlineCount">1</span>
    </div>


    <header class="top-bar">
        <div class="logo" onclick="switchTab('generator')" style="cursor: pointer;">
            <img src="noFilter_1.webp" alt="Logo" class="logo-img" onerror="this.style.display='none'">
            ICEHUB
        </div>

        <div class="user-profile-container" id="navProfileWrapper" style="display: none;">
            <div class="user-profile" id="navProfile" onclick="document.getElementById('profileMenu').classList.toggle('open'); this.classList.toggle('active');">
                <img id="navPfp" class="user-pfp" src="" alt="User">
                <span id="navUsername" class="user-name">User</span>
                <svg class="profile-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </div>

            <div class="profile-dropdown" id="profileMenu">
                <div class="pd-banner" id="pdBanner"></div>
                <div class="pd-header">
                    <img class="pd-pfp" id="pdPfp" src="" alt="Avatar">
                    <div class="pd-name"><span id="pdName">User</span> <span class="pd-badge" id="pdBadge">USER</span></div>
                    <div class="pd-id" id="pdId">000000000000000000</div>
                </div>
                <div class="pd-stats">
                    <div class="pd-stat-row"><span>System Status</span><span class="pd-stat-val" style="color: var(--ok);">CONNECTED</span></div>
                    <div class="pd-stat-row"><span>Network Latency</span><span class="pd-stat-val" id="pdPing">12ms</span></div>
                    <div class="pd-stat-row"><span>Access Level</span><span class="pd-stat-val" id="pdAccessLevel" style="color: var(--blue-lt);">AUTHORIZED</span></div>
                </div>
                <a href="/auth/logout" class="pd-logout">LOG OUT</a>
            </div>
        </div>
    </header>

    <div id="authWall">
        <div class="auth-card">
            <h2>SYSTEM AUTH</h2>
            <p>Establish secure connection via Discord to initialize.</p>
            <button class="btn-discord" onclick="window.location.href='/auth/discord'">
                <svg width="24" height="24" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.31,60,73.31,53s5-12.74,11.43-12.74S96.2,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
                AUTHORIZE CONNECTION
            </button>
        </div>
    </div>

    <div id="appWrapper">
        <nav>
            <button class="nav-btn active" onclick="switchTab('generator')">GENERATOR</button>
            <button class="nav-btn" onclick="switchTab('logs'); fetchGlobalLogs();">GLOBAL LOGS</button>
            <button class="nav-btn" onclick="switchTab('mylogs'); fetchMyLogs();">MY LOGS</button>
            <button class="nav-btn" onclick="switchTab('tutorial')">TUTORIAL</button>
            <button class="nav-btn" onclick="switchTab('credits')">CREDITS</button>
            <button id="navAdminBtn" class="nav-btn" style="display: none; color: #ff4444;" onclick="switchTab('admin')">ADMIN</button>
        </nav>

        <main style="width: 100%;">

            <div id="generator" class="tab-content active">
                <div class="layout-grid">

                    <div class="glass-panel">
                        <div class="panel-header">Configuration</div>

                        <div class="form-group">
                            <label>ROBLOX USERNAME</label>
                            <div class="input-wrapper">
                                <input type="text" class="input-styled" id="rbxInput" placeholder="Enter username..." oninput="debounceFetchId()">
                            </div>
                            <div class="status-text" id="idStatus"></div>

                            <div id="rbxUserCard" class="rbx-user-card" style="display: none;">
                                <div class="rbx-card-left">
                                    <img id="rbxAvatar" src="" alt="Avatar">
                                    <div class="rbx-names">
                                        <span class="rbx-displayname" id="rbxDisplay">Name</span>
                                        <span class="rbx-username" id="rbxName">@user</span>
                                    </div>
                                </div>
                                <div class="rbx-id-badge" id="rbxBadge">ID</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>DISCORD WEBHOOK (OPTIONAL)</label>
                            <input type="text" class="input-styled" id="webhook" placeholder="https://discord.com/api/webhooks/...">
                        </div>

                        <div class="form-group">
                            <label>TARGET BRAINROTS</label>
                            <div class="dropdown" id="petDropdown">
                                <div class="dropdown-trigger" onclick="document.getElementById('petDropdown').classList.toggle('open');">
                                    <span id="selectedCount" style="font-weight: 700; color: #fff;">0 selected</span>
                                    <span style="font-size: 10px; color: var(--blue-lt);">▼</span>
                                </div>
                                <div class="dropdown-menu" id="petDropdownMenu">
                                    <div class="search-box">
                                        <input type="text" id="petSearch" placeholder="Query database..." oninput="filterPets()">
                                        <button type="button" class="btn-convert" style="width: 100%; margin-top: 8px; padding: 8px; text-align: center; border-radius: 6px;" onclick="selectAllSecrets()">+ SELECT ALL SECRETS</button>
                                    </div>
                                    <div class="pet-list" id="petListContainer"></div>
                                </div>
                            </div>
                            <div class="tags-container" id="tagsContainer"></div>
                        </div>

                        <div class="form-group">
                            <label>SCRIPT MODE</label>
                            <div class="mode-selector">
                                <div class="mode-slider" id="modeSlider" style="transform: translateX(0%);"></div>
                                <button class="mode-btn active" onclick="setMode(this, 'NO-GUI', 0)">NO-GUI</button>
                                <button class="mode-btn" onclick="setMode(this, 'FREEZE', 1)">FREEZE</button>
                                <button class="mode-btn" onclick="setMode(this, 'CUSTOM', 2)">CUSTOM</button>
                            </div>

                            <div id="customSettings" class="custom-settings">
                                <div class="toggle-row">
                                    <span class="toggle-label">FREEZE TRADE</span>
                                    <label class="switch">
                                        <input type="checkbox" id="toggleFreeze">
                                        <span class="slider"></span>
                                    </label>
                                </div>
                                <div class="toggle-row">
                                    <span class="toggle-label">FORCE ACCEPT</span>
                                    <label class="switch">
                                        <input type="checkbox" id="toggleAccept">
                                        <span class="slider"></span>
                                    </label>
                                </div>
                                <div class="toggle-row">
                                    <span class="toggle-label">FORCE ADD</span>
                                    <label class="switch">
                                        <input type="checkbox" id="toggleAdd">
                                        <span class="slider"></span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="custom-settings show" style="margin-top: 16px; border-color: rgba(29,107,252,.3);">
                            <div class="toggle-row">
                                <div>
                                    <span class="toggle-label" style="color: #fff; font-size: 13px;">OUTPUT AS LOADSTRING</span>
                                    <div style="font-size: 11px; color: var(--dim); margin-top: 4px;">Automatically hosts and generates a 1-line script.</div>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" id="toggleHost" checked>
                                    <span class="slider"></span>
                                </label>
                            </div>
                        </div>

                        <div class="form-group" style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--b0);">
                            <label>LOADSTRING CONVERTER</label>
                            <div style="font-size: 10.5px; color: var(--dim); margin-bottom: 8px; line-height: 1.4;">
                                Already obfuscated your code? Paste your Pastefy link here.
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" class="input-styled" id="pastefyInput" placeholder="https://pastefy.app/..." style="flex: 1;">
                                <button class="btn-convert" onclick="convertLoadstring()">CONVERT</button>
                            </div>
                        </div>

                        <button class="btn-generate" onclick="generateScript()">
                            GENERATE SCRIPT
                        </button>
                    </div>

                    <div class="glass-panel output-panel">
                        <div class="output-header">
                            <span class="terminal-title">TERMINAL OUTPUT</span>
                            <button class="copy-btn" id="copyBtn" onclick="copyCode()">COPY</button>
                        </div>
                        <div class="terminal-body">
                            <div id="outputPlaceholder" class="placeholder-text">
                                <span>&gt;_</span>
                                <span>WAITING FOR INPUT...</span>
                            </div>
                            <pre id="codeOutput" style="display: none;"></pre>
                        </div>
                    </div>

                </div>
            </div>

            <div id="logs" class="tab-content">
                <div style="text-align: center; margin-bottom: 30px;">
                    <h2 style="font-size: 32px; font-weight: 800; color: #fff;">Global Logs</h2>
                    <p style="color: var(--dim); margin-top: 10px;">Live feed of successful generations around the world.</p>
                </div>
                <div class="glass-panel" style="max-width: 900px; margin: 0 auto; min-height: 500px;">
                    <div class="panel-header" style="justify-content: space-between;">
                        <span>LIVE GLOBAL HITS</span>
                        <button class="btn-convert" onclick="fetchGlobalLogs()" style="padding: 6px 12px;">REFRESH</button>
                    </div>
                    <div id="logContainer" style="display: flex; flex-direction: column; gap: 10px; max-height: 600px; overflow-y: auto; padding-right: 10px;">
                        <div class="placeholder-text" style="position: static; transform: none; text-align: center; padding: 40px;">Waiting for Discord hits...</div>
                    </div>
                </div>
            </div>

            <div id="mylogs" class="tab-content">
                <div style="text-align: center; margin-bottom: 30px;">
                    <h2 style="font-size: 32px; font-weight: 800; color: #fff;">My Logs</h2>
                    <p style="color: var(--dim); margin-top: 10px;">Private history of your personal successful hits.</p>
                </div>

                <div style="display: flex; align-items: center; justify-content: flex-end; max-width: 900px; margin: 0 auto 15px auto;">
                    <div class="toggle-row" style="background: rgba(29,107,252,.05); padding: 8px 16px; border-radius: 8px; border: 1px solid var(--b0);">
                        <span class="toggle-label" style="color: #fff; margin-right: 12px;">SOUND NOTIFICATIONS</span>
                        <label class="switch">
                            <input type="checkbox" id="soundToggle">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <div class="glass-panel" style="max-width: 900px; margin: 0 auto; min-height: 500px;">
                    <div class="panel-header" style="justify-content: space-between;">
                        <span>YOUR PERSONAL HISTORY</span>
                        <div style="display: flex; gap: 8px;">
                            <button class="btn-convert" onclick="clearMyLogs()" style="padding: 6px 12px; background: rgba(248,113,113,.1); border-color: rgba(248,113,113,.3); color: var(--err);">CLEAR LOGS</button>
                            <button class="btn-convert" onclick="fetchMyLogs()" style="padding: 6px 12px;">REFRESH</button>
                        </div>
                    </div>
                    <div id="myLogContainer" style="display: flex; flex-direction: column; gap: 10px; max-height: 600px; overflow-y: auto; padding-right: 10px;">
                        <div class="placeholder-text" style="position: static; transform: none; text-align: center; padding: 40px;">No personal hits recorded yet. Secure key ready.</div>
                    </div>
                </div>
            </div>

            <div id="tutorial" class="tab-content">
                <div style="text-align: center; margin-bottom: 30px;">
                    <h2 style="font-size: 32px; font-weight: 800; color: #fff;">Tutorial</h2>
                    <p style="color: var(--dim); margin-top: 10px;">Learn how to properly configure and obfuscate your loaders.</p>
                </div>

                <div class="guide-container">
                    <div class="guide-step">
                        <div class="step-badge">1</div>
                        <div class="step-content">
                            <h3>Generate Your Script</h3>
                            <p>Fill out your username and select your target pets on the Generator tab. Click <b>GENERATE SCRIPT</b> and copy the code from the terminal.</p>
                            <img src="details.png" alt="Step 1: Generate Script" onclick="openImageModal(this.src)">
                        </div>
                    </div>
                    <div class="guide-step">
                        <div class="step-badge">2</div>
                        <div class="step-content">
                            <h3>Obfuscate Your Code</h3>
                            <p>Go to the <a href="https://wearedevs.net/obfuscator" target="_blank" class="guide-link">WeAreDevs Obfuscator</a>. Paste your raw code into their text box, click Obfuscate, and copy the new, scrambled code.</p>
                            <img src="obfuscatestep.png" alt="Step 2: Obfuscate Code" onclick="openImageModal(this.src)">
                        </div>
                    </div>
                    <div class="guide-step">
                        <div class="step-badge">3</div>
                        <div class="step-content">
                            <h3>Host on Pastefy</h3>
                            <p>Go to <a href="https://pastefy.app/" target="_blank" class="guide-link">Pastefy.app</a>. Paste your obfuscated code there, hit save/submit, and copy the link from your browser's address bar.</p>
                            <img src="linkmaker.png" alt="Step 3: Host on Pastefy" onclick="openImageModal(this.src)">
                        </div>
                    </div>
                    <div class="guide-step">
                        <div class="step-badge">4</div>
                        <div class="step-content">
                            <h3>Create Your Loadstring</h3>
                            <p>Come back to IceHub. Paste your Pastefy link into the <b>Loadstring Converter</b> box and click Convert. You now have a secure loader you can safely share or execute!</p>
                            <img src="convert.png" alt="Step 4: Create Loadstring" onclick="openImageModal(this.src)">
                        </div>
                    </div>
                </div>
            </div>

            <div id="credits" class="tab-content">
                <div style="text-align: center; margin-bottom: 30px;">
                    <h2 style="font-size: 36px; font-weight: 800; color: #fff;">ICEHUB</h2>
                    <p style="color: var(--dim); margin-top: 10px;">The team behind the magic.</p>
                </div>

                <div class="credits-grid">
                    <div class="dev-card" id="dev1">
                        <div class="dev-banner"></div>
                        <img class="dev-pfp" id="dev1Pfp" src="" alt="Dev" onerror="this.style.display='none'">
                        <div class="dev-info">
                            <div class="dev-name"><span id="dev1Name">Loading...</span> <span class="dev-badge" id="dev1Badge">DEV</span></div>
                            <div class="dev-id">ID: 1426302178024231043</div>
                            <a href="https://discord.com/users/1426302178024231043" target="_blank" class="dev-btn">VIEW PROFILE</a>
                        </div>
                    </div>
                    <div class="dev-card" id="dev2">
                        <div class="dev-banner"></div>
                        <img class="dev-pfp" id="dev2Pfp" src="" alt="Dev" onerror="this.style.display='none'">
                        <div class="dev-info">
                            <div class="dev-name"><span id="dev2Name">Loading...</span> <span class="dev-badge" id="dev2Badge">DEV</span></div>
                            <div class="dev-id">ID: 1435374811957170347</div>
                            <a href="https://discord.com/users/1435374811957170347" target="_blank" class="dev-btn">VIEW PROFILE</a>
                        </div>
                    </div>
                </div>

                <div class="special-thanks-container">
                    <p class="thanks-text">Much credits to <b style="color: #fff;">Limited Hub</b> for helping make this possible. Check their hub out (:</p>

                    <div class="discord-invite-card">
                        <div class="invite-header">YOU'VE BEEN INVITED TO JOIN A SERVER</div>
                        <div class="invite-body">
                            <img id="inviteIcon1" src="https://cdn.discordapp.com/embed/avatars/0.png" class="invite-icon" alt="Server Icon">
                            <div class="invite-details">
                                <div id="inviteName1" class="invite-name">Limited Hub</div>
                                <div class="invite-counts">
                                    <div class="count-item"><span class="status-dot online"></span><span id="inviteOnline1">... Online</span></div>
                                    <div class="count-item"><span class="status-dot offline"></span><span id="inviteTotal1">... Members</span></div>
                                </div>
                            </div>
                            <a href="https://discord.gg/sabscripts" target="_blank" class="btn-join">Join</a>
                        </div>
                    </div>

                    <div style="margin-top: 20px; font-size: 13px; color: var(--dim);">IceHub Official Discord:</div>

                    <div class="discord-invite-card">
                        <div class="invite-header">YOU'VE BEEN INVITED TO JOIN A SERVER</div>
                        <div class="invite-body">
                            <img id="inviteIcon2" src="https://cdn.discordapp.com/embed/avatars/0.png" class="invite-icon" alt="Server Icon">
                            <div class="invite-details">
                                <div id="inviteName2" class="invite-name">IceHub</div>
                                <div class="invite-counts">
                                    <div class="count-item"><span class="status-dot online"></span><span id="inviteOnline2">... Online</span></div>
                                    <div class="count-item"><span class="status-dot offline"></span><span id="inviteTotal2">... Members</span></div>
                                </div>
                            </div>
                            <a href="https://discord.gg/icehub" target="_blank" class="btn-join">Join</a>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <div id="admin" class="tab-content">
                <div style="text-align: center; margin-bottom: 30px;">
                    <h2 style="font-size: 32px; font-weight: 800; color: #ff4444; letter-spacing: -0.5px;">Admin Control Panel</h2>
                    <p style="color: var(--dim); margin-top: 10px;">Authorized Access Only.</p>
                </div>

                <div style="max-width: 800px; margin: 0 auto;">
                    <div class="glass-panel" style="border-top: 3px solid #ff4444;">
                        <div class="panel-header" style="color: #ff4444;">System Management</div>

                        <div class="form-group">
                            <label>SET GLOBAL ANNOUNCEMENT</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" class="input-styled" id="announcementInput" placeholder="Leave blank to remove announcement..." style="flex: 1;">
                                <button class="btn-convert" onclick="setAnnouncement()">UPDATE</button>
                            </div>
                        </div>

                        <div class="form-group" style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--b0);">
                            <label>BLACKLIST / UNBLACKLIST DISCORD ID</label>
                            <div style="display: flex; gap: 8px; margin-bottom: 8px;">
                                <input type="text" class="input-styled" id="blacklistInput" placeholder="Enter Discord ID..." style="flex: 1;">
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" class="input-styled" id="blacklistReason" placeholder="Reason (e.g. Trying to spoof)..." style="flex: 2;">
                                <button class="btn-convert" style="background: rgba(248,113,113,.1); border-color: rgba(248,113,113,.3); color: var(--err); flex: 1;" onclick="handleBlacklist('ban')">BAN</button>
                                <button class="btn-convert" style="background: rgba(52, 211, 153, .1); border-color: rgba(52, 211, 153, .3); color: #34d399; flex: 1;" onclick="handleBlacklist('unban')">UNBAN</button>
                            </div>
                        </div>

                        <div class="form-group" style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--b0);">
                            <label style="color: var(--err);">DANGER ZONE</label>
                            <button class="btn-generate" style="background: rgba(248,113,113,.1); border-color: rgba(248,113,113,.3); color: var(--err); width: 100%; margin-top: 5px;" onclick="clearGlobalLogs()">WIPE ALL GLOBAL LOGS</button>
                        </div>
                    </div>
                </div>
            </div>

    <div id="toast" class="toast">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
        Copied
    </div>

    <script>
        const RAW_PET_DATABASE = [
