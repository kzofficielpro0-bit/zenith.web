<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Zenith Shop</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      text-align: center;
    }

    header {
      padding: 20px;
      background: #020617;
      font-size: 28px;
      font-weight: bold;
    }

    .container {
      padding: 40px;
    }

    .product {
      background: #1e293b;
      padding: 20px;
      margin: 20px auto;
      width: 300px;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .product h2 {
      margin-bottom: 10px;
    }

    .price {
      color: #38bdf8;
      font-size: 20px;
      margin: 10px 0;
    }

    .buy-btn {
      background: #22c55e;
      border: none;
      padding: 10px 20px;
      color: white;
      font-size: 16px;
      cursor: pointer;
      border-radius: 5px;
    }

    .buy-btn:hover {
      background: #16a34a;
    }

    footer {
      margin-top: 40px;
      padding: 10px;
      background: #020617;
      font-size: 14px;
    }
  </style>
</head>

<body>

<header>⚡ Zenith Shop ⚡</header>

<div class="container">

  <div class="product">
    <h2>ZENITH DUEL</h2>
    <p>Script PvP avancé</p>
    <div class="price">10€</div>
    <button class="buy-btn" onclick="buy('ZENITH DUEL')">Buy Script</button>
  </div>

  <div class="product">
    <h2>ZENITH SEMI TP</h2>
    <p>Script téléportation</p>
    <div class="price">8€</div>
    <button class="buy-btn" onclick="buy('ZENITH SEMI TP')">Buy Script</button>
  </div>

  <div class="product">
    <h2>SOON</h2>
    <p>Prochain script...</p>
    <div class="price">???</div>
    <button class="buy-btn" disabled>Coming Soon</button>
  </div>

</div>

<footer>
  © 2026 Zenith Shop
</footer>

<script>
function buy(product) {
  // REMPLACE PAR TON LIEN PAYPAL
  window.location.href = "https://paypal.me/TONPSEUDO";
}
</script>

</body>
</html>
